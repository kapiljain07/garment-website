PORT=5000
CLIENT_ORIGIN=http://localhost:5173
ADMIN_TOKEN=change_me_to_secure_token

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# SUPABASE SETUP REQUIRED:
# ============================================
# 1. Tables expected in Supabase:
#    - products (id uuid default uuid_generate_v4() primary key, name text, category text, description text, image_url text, created_at timestamptz default now())
#    - contacts (id uuid default uuid_generate_v4() primary key, name text, email text, phone text, message text, created_at timestamptz default now())
#
# 2. Storage bucket required:
#    - Create a bucket named "products" in Supabase Storage
#    - Set the bucket to PUBLIC for images to be viewable
#    - Go to Storage > products > Policies > Add policy for SELECT (public read)
#
# ============================================
# PRODUCTION DEPLOYMENT:
# ============================================
# For Render deployment, set these environment variables:
# - CLIENT_ORIGIN: Your Netlify frontend URL (e.g., https://your-site.netlify.app)
# - ADMIN_TOKEN: A strong, unique token for admin authentication
# - SUPABASE_URL: Your Supabase project URL
# - SUPABASE_SERVICE_ROLE_KEY: Your Supabase service role key

